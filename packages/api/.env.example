# ── Required ──────────────────────────────────────────────────────────────────

# Supabase project URL (Settings > API > Project URL)
SUPABASE_URL=https://<ref>.supabase.co

# Supabase public anon key (Settings > API > anon public)
SUPABASE_ANON_KEY=eyJ...

# Supabase service role key — bypasses RLS, never expose to clients
# (Settings > API > service_role secret)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# AES-256-GCM master key for encrypting integration secrets at rest.
# Must be 32 bytes, base64-encoded.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Default Groq API key (users can override with their own via /api/integrations/groq)
# Free at https://console.groq.com
GROQ_API_KEY=gsk_...

# ── Server ────────────────────────────────────────────────────────────────────

PORT=3000

# Comma-separated list of allowed CORS origins
# Leave empty to block all cross-origin requests
ALLOWED_ORIGINS=http://localhost:5173,https://app.yoursite.com

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Required for distributed rate limiting across multiple API instances.
# Without this, rate limiting is a no-op (each process has no shared state).
REDIS_URL=redis://localhost:6379

# ── Telegram webhook (optional) ───────────────────────────────────────────────
# Required only if using the POST /webhook/telegram endpoint.

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Secret token sent by Telegram in the X-Telegram-Bot-Api-Secret-Token header.
# Set this when registering the webhook:
#   curl "https://api.telegram.org/bot<TOKEN>/setWebhook"
#     -d "url=https://your-api.com/webhook/telegram"
#     -d "secret_token=<this-value>"
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ── WhatsApp Cloud API (optional) ────────────────────────────────────────────
# Required only if using the GET+POST /webhook/whatsapp endpoints.
# All four values come from the Meta for Developers dashboard:
#   developers.facebook.com → Your App → WhatsApp → API Setup

# Permanent access token (or a system user token from Business Manager)
WHATSAPP_ACCESS_TOKEN=

# Phone Number ID (not the phone number itself) from the API Setup page
WHATSAPP_PHONE_NUMBER_ID=

# Your custom string for webhook verification (you choose this value)
# Set it when registering the webhook in the Meta dashboard Webhooks section
# Generate: openssl rand -hex 32
WHATSAPP_VERIFY_TOKEN=

# App Secret from App Settings > Basic — used to verify X-Hub-Signature-256
WHATSAPP_APP_SECRET=

# ── Public API base URL (optional) ────────────────────────────────────────────
# Used to build magic-link email redirect URLs for WhatsApp account linking.
# Example: https://api.yoursite.com
API_BASE_URL=

# ── Email security (optional) ─────────────────────────────────────────────────
# Comma-separated list of allowed recipient domains for email_send actions.
# Leave empty to allow any domain.
# Example: gmail.com,yourcompany.com
ALLOWED_EMAIL_DOMAINS=
